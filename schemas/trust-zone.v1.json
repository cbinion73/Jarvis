{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/trust-zone.v1.json",
  "title": "TrustZoneV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "zone_id",
    "name",
    "zone_type",
    "resource_scope",
    "allowed_actions",
    "approval_mode",
    "audit_mode",
    "promotion_rules",
    "demotion_rules",
    "status"
  ],
  "properties": {
    "zone_id": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "zone_type": {
      "type": "string",
      "enum": ["observe", "draft_stage", "sandbox_live", "mature_live"]
    },
    "resource_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["systems", "data_classes"],
      "properties": {
        "systems": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "data_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "account_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "connector_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "observe",
          "classify",
          "infer",
          "recommend",
          "draft",
          "stage",
          "alert",
          "simulate",
          "execute_in_zone",
          "rebalance_in_zone",
          "spawn_agent_in_zone",
          "retire_agent_in_zone",
          "store_memory",
          "retire_memory"
        ]
      }
    },
    "approval_mode": {
      "type": "string",
      "enum": [
        "none_in_zone",
        "draft_only",
        "stage_and_alert",
        "promotion_required",
        "boundary_escalation_only"
      ]
    },
    "audit_mode": {
      "type": "string",
      "enum": ["minimal", "standard", "detailed"]
    },
    "reporting_cadence": {
      "type": "string",
      "enum": ["event_driven", "hourly", "daily", "weekly", "on_request"]
    },
    "promotion_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eligible_next_stages", "minimum_success_rate", "minimum_review_count"],
      "properties": {
        "eligible_next_stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["draft", "stage_alert", "sandbox_live", "mature_live"]
          }
        },
        "minimum_success_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "minimum_review_count": {
          "type": "integer",
          "minimum": 0
        },
        "required_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "demotion_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["triggers"],
      "properties": {
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "boundary_violation",
              "hidden_action",
              "false_confidence",
              "error_rate_breach",
              "reporting_failure",
              "manual_override"
            ]
          }
        },
        "fallback_stage": {
          "type": "string",
          "enum": ["observe", "draft", "stage_alert", "sandbox_live", "suspended"]
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "retired"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
