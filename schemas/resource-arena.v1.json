{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/resource-arena.v1.json",
  "title": "ResourceArenaV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "arena_id",
    "name",
    "resource_type",
    "linked_zone_id",
    "owner_principal",
    "risk_class",
    "limits",
    "pause_conditions",
    "status"
  ],
  "properties": {
    "arena_id": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "resource_type": {
      "type": "string",
      "enum": [
        "email_draft_pipeline",
        "brokerage_sandbox",
        "research_workspace",
        "planning_workspace",
        "automation_account"
      ]
    },
    "linked_zone_id": {
      "type": "string",
      "pattern": "^[a-z0-9._-]+$"
    },
    "owner_principal": {
      "type": "string"
    },
    "risk_class": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "resource_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "account_id": { "type": "string" },
        "mailbox_id": { "type": "string" },
        "folder_id": { "type": "string" },
        "workspace_id": { "type": "string" }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_budget"],
      "properties": {
        "action_budget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_actions_per_day": { "type": "integer", "minimum": 0 },
            "max_drafts_per_day": { "type": "integer", "minimum": 0 },
            "max_trades_per_day": { "type": "integer", "minimum": 0 }
          }
        },
        "financial_limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_notional_usd": { "type": "number", "minimum": 0 },
            "max_loss_usd": { "type": "number", "minimum": 0 },
            "allowed_instruments": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "message_limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "send_enabled": { "type": "boolean" },
            "draft_folder_required": { "type": "boolean" },
            "allowed_recipient_classes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "pause_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "promotion_eligibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "target_stage": {
          "type": "string",
          "enum": ["draft", "stage_alert", "sandbox_live", "mature_live"]
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "retired"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
