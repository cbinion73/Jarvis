{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/schemas/authority-stage.v1.json",
  "title": "AuthorityStageV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stage_id",
    "name",
    "sequence",
    "allowed_action_types",
    "approval_requirements",
    "reporting_requirements",
    "promotion_criteria",
    "demotion_triggers",
    "status"
  ],
  "properties": {
    "stage_id": {
      "type": "string",
      "enum": ["observe", "draft", "stage_alert", "sandbox_live", "mature_live", "suspended"]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "allowed_action_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "approval_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pre_action", "boundary_crossing"],
      "properties": {
        "pre_action": {
          "type": "string",
          "enum": ["none", "required", "draft_only", "stage_and_alert"]
        },
        "boundary_crossing": {
          "type": "string",
          "enum": ["escalate", "deny", "require_human_approval"]
        }
      }
    },
    "reporting_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary_level", "cadence"],
      "properties": {
        "summary_level": {
          "type": "string",
          "enum": ["minimal", "standard", "detailed"]
        },
        "cadence": {
          "type": "string",
          "enum": ["per_action", "hourly", "daily", "weekly", "on_request"]
        },
        "must_capture_outcomes": {
          "type": "boolean"
        }
      }
    },
    "promotion_criteria": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum_success_rate", "minimum_review_count"],
      "properties": {
        "minimum_success_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "minimum_review_count": {
          "type": "integer",
          "minimum": 0
        },
        "maximum_boundary_violations": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "demotion_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "boundary_violation",
          "hidden_action",
          "false_confidence",
          "error_rate_breach",
          "reporting_failure",
          "principal_override"
        ]
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "retired"]
    }
  }
}
