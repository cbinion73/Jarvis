+++ b/jarvis/config.py
@@ -29,6 +29,51 @@ def load_env_file(path: Path) -> None:
         os.environ.setdefault(key.strip(), value.strip())
 
 
+def resolve_google_maps_api_key() -> str:
+    candidates = [
+        os.getenv("GOOGLE_MAPS_API_KEY", ""),
+        os.getenv("GOOGLE_API_KEY", ""),
+        os.getenv("GOOGLE_CLIENT_SECRET", ""),
+    ]
+    for candidate in candidates:
+        cleaned = _normalize_google_maps_api_key(candidate)
+        if cleaned:
+            return cleaned
+
+    client_secret_path = Path(
+        os.getenv(
+            "JARVIS_GOOGLE_CLIENT_SECRET",
+            "config/google_client_secret.json",
+        )
+    )
+    if client_secret_path.exists():
+        try:
+            payload = json.loads(client_secret_path.read_text(encoding="utf-8"))
+        except Exception:
+            payload = {}
+        if isinstance(payload, dict):
+            for key in ("api_key", "maps_api_key"):
+                cleaned = _normalize_google_maps_api_key(payload.get(key, ""))
+                if cleaned:
+                    return cleaned
+            for section in ("installed", "web"):
+                block = payload.get(section)
+                if not isinstance(block, dict):
+                    continue
+                for key in ("api_key", "maps_api_key"):
+                    cleaned = _normalize_google_maps_api_key(block.get(key, ""))
+                    if cleaned:
+                        return cleaned
+    return ""
+
+
+def _normalize_google_maps_api_key(value: object) -> str:
+    cleaned = str(value or "").strip()
+    if cleaned.startswith("AIza") and len(cleaned) >= 20:
+        return cleaned
+    return ""
+
