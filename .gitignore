.env
.venv/
.venv-openviking/
__pycache__/
*.pyc
.DS_Store
.qlpreview/
*.log
*.sqlite
*.db
*.db-wal
*.db-shm

# ── Credentials & secrets ────────────────────────────────────────────────────
config/google_client_secret.json
config/openviking/
# GCP service-account key
config/cobalt-list-385701-8a97dbcce1b5.json

# OAuth tokens
data/google/
data/openviking/
data/microsoft_graph/

# APNs — private signing key and config with key_id/team_id
data/settings/apns_key.p8
data/settings/apns_config.json

# CloudflareConfig contains live CF-Access service token credentials
CloudflareConfig.swift

# ── Runtime data — changes every server tick, not source ────────────────────
data/agents/*
!data/agents/jarvis_agent_registry.v1.json
data/cache/
data/conversations/
data/camera_hls/
# uploaded photos — can be large
data/forge/jobs/
data/system/worktrees/

# Runtime logs (*.jsonl files live here)
data/logs/
data/archive/
data/settings/*_log.jsonl
data/settings/*_state_log.jsonl
data/agents/*_state_log.jsonl

# Operational queues and live workstream state
data/workstreams/

# Live weather / security advisories fetched at runtime
data/weather/
data/security/

# Family activity history and trust runtime state
data/family/mode_history.jsonl
data/trust/trust_zones.json
data/**/*.lock
data/**/*_log.jsonl
data/**/*_state_log.jsonl
data/state/
data/infra/

# Settings generated or updated at runtime
data/settings/adaptation_profiles.json
data/settings/assistant_core.json
# Unbounded append-only runtime logs — can grow to GB+
data/settings/assistant_core_log.jsonl
data/settings/assistant_core_state_log.jsonl
data/settings/faith_daily_word.json
data/settings/identity.json
data/settings/layout_state.json
data/settings/sam_protocol_today.json
data/settings/profiles/
data/settings/layout_weights_cache.json
data/workshop/model_forge/

# ── Xcode / Swift build artifacts ───────────────────────────────────────────
JarvisApple/.build/
JarvisApple/.derivedData*/
JarvisApple/.swiftpm/xcode/xcuserdata/
JarvisApple/**/*.xcodeproj/project.xcworkspace/xcuserdata/
JarvisApple/**/*.xcodeproj/xcuserdata/
*.xcuserstate

# ── Large binary voice models (use Git LFS or store outside repo) ────────────
*.onnx
assets/piper/voices/

# ── Vendor ML repos — large weights and compiled binaries ───────────────────
vendor/stable-fast-3d/.venv/
vendor/trellis-mac/.venv/
vendor/trellis-mac/deps/
vendor/trellis-mac/TRELLIS.2/
vendor/trellis-mac/
vendor/**/*.so
vendor/**/*.dylib
vendor/**/__pycache__/

